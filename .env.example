# Application
PROJECT_NAME=E-Commerce-Customer-Service
VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars

# Database
DATABASE_URL=mysql+aiomysql://cs_user:cs_password@localhost:3306/customer_service
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# LLM Provider (openai / anthropic / local)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-4-turbo-preview
LLM_API_BASE=https://api.openai.com/v1
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Local LLM (used when LLM_PROVIDER=local)
LOCAL_LLM_API_BASE=http://localhost:8000/v1
LOCAL_LLM_MODEL=Qwen/Qwen2-72B-Instruct

# Embedding Provider (openai / local)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# Vector Store (milvus / qdrant / chroma)
VECTOR_STORE_TYPE=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]

# File Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-attachments

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
